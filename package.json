{
  "name": "educational-game",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "test": "node --test tests/*.test.mjs",
    "validate:tasks": "node scripts/validate-tasks.mjs",
    "check": "npm run lint && npm run validate:tasks && npm run test",
    "test:js": "node --test tests/js-module-quality.test.mjs",
    "validate:js": "node scripts/validate-js-module.mjs",
    "check:js": "npm run validate:js && npm run test:js"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "prettier": "^3.5.3"
  }
}
